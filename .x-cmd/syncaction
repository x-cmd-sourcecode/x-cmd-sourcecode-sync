
# Modernized syncaction for x-cmd-action (post-2022)
#
# Strategy:
# - Clone the catalog (x-cmd-sourcecode/sourcecode) once
# - Run backups in parallel via xargs (CONCURRENCY from env, default 10)
# - For each lib/* entry: shallow bare clone upstream, push refs to the
#   GitHub target. Gitee target is best-effort (most repos don't exist
#   there yet; see follow-up to create them in batch).
# - Shallow clone (--depth 1) is fine for a daily mirror: we only need the
#   tip of each ref. x gitb backup used a full clone which timed out on
#   huge repos (curl/openssl/neovim/lua all 10+ min each).
# - Catalog files like README.removed are skipped (non GIT-HTTP).

git clone git@github.com:x-cmd-sourcecode/sourcecode.git /tmp/sourcecode
cd /tmp/sourcecode || exit 1

# Emit one job per lib entry; xargs fans them out.
for entry in lib/*; do
    [ -f "$entry" ] || continue
    SOURCE_TYPE=
    SOURCE_URL=
    SOURCE_TGTNAME=
    . "$entry"

    [ "$SOURCE_TYPE" = "GIT-HTTP" ] || {
        echo "skip (non GIT-HTTP): $entry"
        continue
    }

    printf '%s\n' "$SOURCE_TGTNAME|$SOURCE_URL"
done | xargs -d '\n' -P "${CONCURRENCY:-10}" -I {} sh -c '
    entry="{}"
    name="${entry%%|*}"
    url="${entry#*|}"
    echo "==> backup: $name  (from $url)"

    workdir=$(mktemp -d)
    cd "$workdir" || exit 1

    # Shallow bare clone — tip of every ref, no history. Fast even for
    # huge repos like curl/openssl.
    if ! git clone --depth 1 --bare --no-tags "$url" "$name" 2>/dev/null; then
        # Some upstreams don'\''t accept shallow clone (e.g. server missing
        # upload-pack.allowfilter). Fall back to no-tags full bare.
        git clone --bare "$url" "$name" 2>/dev/null || {
            echo "FAIL clone: $name  (from $url)"
            cd /; rm -rf "$workdir"
            exit 0
        }
    fi
    cd "$name" || { cd /; rm -rf "$workdir"; exit 0; }

    # Fetch all branches/tags shallowly so push --mirror carries them.
    git remote remove origin 2>/dev/null
    git remote add origin "$url"
    git fetch --depth 1 origin "+refs/heads/*:refs/heads/*" "+refs/tags/*:refs/tags/*" 2>/dev/null || true

    # Push to GitHub — the contract.
    if git push --mirror "git@github.com:x-cmd-sourcecode/$name" 2>&1 | sed "s/^/  [github] /"; then
        echo "  [github] OK: $name"
    else
        echo "FAIL github: $name"
    fi

    # Push to Gitee — best-effort. Repos may not exist yet (404).
    if git push --mirror "git@gitee.com:x-cmd-sourcecode/$name" 2>&1 | sed "s/^/  [gitee] /"; then
        echo "  [gitee] OK: $name"
    else
        echo "  [gitee] skip-or-fail: $name"
    fi

    cd /
    rm -rf "$workdir"
'
